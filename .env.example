DB_USER=postgres  
DB_PASSWORD=yourpassword  
DB_NAME=snapl
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/snapl
REDIS_URL=                        # blank = in-memory cache; redis://localhost:6379/0 for Redis
BASE_URL=http://localhost:5600
DEFAULT_EXPIRY_DAYS=30
CACHE_TTL_SECONDS=300
RATE_LIMIT_PER_MINUTE=60

# Auth
JWT_SECRET=                       # required — generate with: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# Admin
ADMIN_SECRET=                     # required to call POST /admin/purge — generate with: openssl rand -hex 16

# Geo analytics (free tier; swap for MaxMind in production)
GEO_API_URL=http://ip-api.com/json/
